---
const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-white mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <div>
        <p class="font-serif text-lg font-bold">ParentCompass<span class="text-gold-400">.ai</span></p>
        <p class="text-gray-400 text-sm mt-1 max-w-xs">
          AI-native year-by-year counsellor from Grade 9 to college admission.
        </p>
      </div>
      <nav class="flex gap-8 text-sm text-gray-400">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="mailto:hello@parentcompass.ai" class="hover:text-white transition-colors">Contact</a>
      </nav>
    </div>
    <div class="border-t border-navy-700 mt-8 pt-8 text-center text-gray-500 text-xs">
      &copy; {year} ParentCompass. All rights reserved.
    </div>
  </div>
</footer>
