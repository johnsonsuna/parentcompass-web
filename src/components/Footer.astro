---
const year = new Date().getFullYear();
---

<footer class="bg-forest-900 text-white">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <div>
        <p class="font-serif text-lg font-bold tracking-tight">
          ParentCompass<span class="text-terra-400">.ai</span>
        </p>
        <p class="text-forest-300 text-sm mt-2 max-w-xs leading-relaxed">
          Year-by-year AI counsellor from Grade 9 to college admission.
        </p>
      </div>
      <nav class="flex gap-8 text-sm text-forest-400">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms</a>
        <a href="mailto:hello@parentcompass.ai" class="hover:text-white transition-colors">Contact</a>
      </nav>
    </div>
    <div class="border-t border-forest-800 mt-10 pt-8 text-center text-forest-500 text-xs">
      &copy; {year} ParentCompass. All rights reserved.
    </div>
  </div>
</footer>
