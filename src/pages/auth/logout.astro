---
export const prerender = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const submittedToken = form.get('csrf')?.toString();
  const cookieToken = Astro.cookies.get('csrf_logout')?.value;

  if (submittedToken && cookieToken && submittedToken === cookieToken) {
    Astro.cookies.delete('csrf_logout', { path: '/' });
    await Astro.locals.supabase.auth.signOut();
  }
}

return Astro.redirect('/');
