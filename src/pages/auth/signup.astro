---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';

if (Astro.locals.user) {
  return Astro.redirect('/dashboard');
}

let error = '';
let success = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString() ?? '';
  const password = form.get('password')?.toString() ?? '';

  const { error: authError } = await Astro.locals.supabase.auth.signUp({
    email,
    password,
    options: {
      emailRedirectTo: `${Astro.url.origin}/auth/callback`,
    },
  });

  if (authError) {
    error = authError.message;
  } else {
    success = true;
  }
}
---

<BaseLayout title="Create Account — ParentCompass" description="Create your ParentCompass family account.">
  <Header />
  <main class="bg-sand-50 min-h-screen flex items-center justify-center px-6 py-20">
    <div class="w-full max-w-md">

      <div class="text-center mb-10">
        <h1 class="text-3xl font-serif font-bold text-forest-800 mb-2">Start your journey</h1>
        <p class="text-stone-500 text-sm font-sans">Create a free account to begin your college planning journey.</p>
      </div>

      {success ? (
        <div class="bg-forest-50 border border-forest-200 text-forest-800 text-sm font-sans px-5 py-4 rounded-lg text-center">
          <p class="font-semibold mb-1">Check your email</p>
          <p class="text-stone-500">We sent a confirmation link to your email address. Click it to activate your account.</p>
        </div>
      ) : (
        <>
          {error && (
            <div class="bg-red-50 border border-red-200 text-red-700 text-sm font-sans px-4 py-3 rounded-lg mb-6">
              {error}
            </div>
          )}
          <form method="POST" class="space-y-5">
            <div>
              <label for="email" class="block text-sm font-sans font-semibold text-stone-600 mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-sand-200 rounded-lg px-4 py-3 font-sans text-sm text-forest-800 focus:outline-none focus:border-forest-600 bg-white"
                placeholder="you@example.com"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-sans font-semibold text-stone-600 mb-1.5">Password</label>
              <input
                type="password"
                id="password"
                name="password"
                required
                minlength="8"
                class="w-full border border-sand-200 rounded-lg px-4 py-3 font-sans text-sm text-forest-800 focus:outline-none focus:border-forest-600 bg-white"
                placeholder="Min. 8 characters"
              />
            </div>
            <button
              type="submit"
              class="w-full bg-terra-500 text-white font-sans font-semibold py-3.5 rounded-lg hover:bg-terra-600 transition-colors"
            >
              Create Account — Free
            </button>
          </form>
          <p class="text-center text-xs font-sans text-stone-400 mt-4 leading-relaxed">
            By signing up you agree to our{' '}
            <a href="/terms" class="underline hover:text-stone-600">Terms</a>{' '}and{' '}
            <a href="/privacy" class="underline hover:text-stone-600">Privacy Policy</a>.
          </p>
          <p class="text-center text-sm font-sans text-stone-400 mt-5">
            Already have an account?{' '}
            <a href="/auth/login" class="text-terra-500 font-semibold hover:underline">Sign in</a>
          </p>
        </>
      )}
    </div>
  </main>
</BaseLayout>
