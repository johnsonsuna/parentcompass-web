---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';

if (Astro.locals.user) {
  return Astro.redirect('/dashboard');
}

let error = '';
let successRedirect = false;

const csrfToken = crypto.randomUUID();

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const submittedToken = form.get('csrf')?.toString();
  const cookieToken = Astro.cookies.get('csrf')?.value;

  if (!submittedToken || submittedToken !== cookieToken) {
    error = 'Invalid request. Please refresh and try again.';
  } else {
    const email = form.get('email')?.toString() ?? '';
    const password = form.get('password')?.toString() ?? '';

    const { error: authError } = await Astro.locals.supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (authError) {
      error = authError.message;
    } else {
      // Client-side redirect ensures the browser processes Set-Cookie headers
      // from this POST response before navigating, avoiding a redirect loop
      // where the session cookies arrive on a 302 that some proxies strip.
      Astro.cookies.delete('csrf', { path: '/' });
      successRedirect = true;
    }
  }
}

Astro.cookies.set('csrf', csrfToken, {
  httpOnly: true,
  sameSite: 'strict',
  path: '/',
  maxAge: 600,
});
---

<BaseLayout title="Sign In — ParentCompass" description="Sign in to your ParentCompass account.">
  <Header />
  <main class="bg-sand-50 min-h-screen flex items-center justify-center px-6 py-20">
    <div class="w-full max-w-md">

      {successRedirect ? (
        <>
          <div class="text-center">
            <p class="text-stone-500 text-sm font-sans">Signing you in…</p>
          </div>
          <script>window.location.replace('/dashboard');</script>
        </>
      ) : (
        <>
          <div class="text-center mb-10">
            <h1 class="text-3xl font-serif font-bold text-forest-800 mb-2">Welcome back</h1>
            <p class="text-stone-500 text-sm font-sans">Sign in to continue your college planning journey.</p>
          </div>

          {error && (
            <div class="bg-red-50 border border-red-200 text-red-700 text-sm font-sans px-4 py-3 rounded-lg mb-6">
              {error}
            </div>
          )}

          <form method="POST" class="space-y-5">
            <input type="hidden" name="csrf" value={csrfToken} />
            <div>
              <label for="email" class="block text-sm font-sans font-semibold text-stone-600 mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-sand-200 rounded-lg px-4 py-3 font-sans text-sm text-forest-800 focus:outline-none focus:border-forest-600 bg-white"
                placeholder="you@example.com"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-sans font-semibold text-stone-600 mb-1.5">Password</label>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="w-full border border-sand-200 rounded-lg px-4 py-3 font-sans text-sm text-forest-800 focus:outline-none focus:border-forest-600 bg-white"
                placeholder="••••••••"
              />
            </div>
            <button
              type="submit"
              class="w-full bg-terra-500 text-white font-sans font-semibold py-3.5 rounded-lg hover:bg-terra-600 transition-colors"
            >
              Sign In
            </button>
          </form>

          <p class="text-center text-sm font-sans text-stone-400 mt-6">
            Don't have an account?{' '}
            <a href="/auth/signup" class="text-terra-500 font-semibold hover:underline">Sign up free</a>
          </p>
        </>
      )}
    </div>
  </main>
</BaseLayout>
