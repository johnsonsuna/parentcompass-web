---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="ParentCompass — AI College Counsellor for Every Year of High School"
  description="Year-by-year AI guidance from Grade 9 through college admission. Structured planning, essay prep, and real-time guidance — at a fraction of the cost of a human counsellor."
>
  <Header />

  <!-- Hero: split layout, left-aligned editorial -->
  <section class="bg-sand-50 py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">

        <!-- Left: Copy -->
        <div>
          <p class="text-terra-500 text-xs font-sans font-bold tracking-widest uppercase mb-5">
            Grade 9 → College Admission
          </p>
          <h1 class="text-5xl md:text-[3.25rem] font-serif font-bold text-forest-800 leading-[1.1] mb-6">
            Your child's college journey deserves a guide,<br class="hidden md:block" /> not a guess.
          </h1>
          <p class="text-stone-600 text-lg font-sans leading-relaxed mb-3 max-w-lg">
            ParentCompass is a year-by-year AI counsellor that grows with your student — from course
            selection in Grade 9 to the final college decision in Grade 12.
          </p>
          <p class="text-stone-400 text-sm font-sans mb-8">
            Human counsellors charge <span class="line-through text-stone-400">$3,000–$15,000</span>.
            We charge <strong class="text-forest-800 font-semibold">$199/year</strong>.
          </p>
          <div class="flex flex-col sm:flex-row gap-3" id="waitlist">
            <a
              href="mailto:hello@parentcompass.ai?subject=Waitlist"
              class="bg-terra-500 text-white font-sans font-semibold px-7 py-4 rounded-lg text-base hover:bg-terra-600 transition-colors text-center"
            >
              Join the Waitlist — Free
            </a>
            <a
              href="#how-it-works"
              class="border border-forest-200 text-forest-700 font-sans font-semibold px-7 py-4 rounded-lg text-base hover:bg-forest-50 transition-colors text-center"
            >
              See how it works
            </a>
          </div>
        </div>

        <!-- Right: Compass visual -->
        <div class="flex justify-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 320 320"
            class="w-64 md:w-80"
            aria-hidden="true"
          >
            <!-- Warm background disc -->
            <circle cx="160" cy="160" r="155" fill="#F5ECD7" stroke="#EDD9B8" stroke-width="1" />

            <!-- Dashed orbit rings -->
            <circle cx="160" cy="160" r="118" fill="none" stroke="#2D6A4F" stroke-width="1" stroke-dasharray="6 8" opacity="0.35" />
            <circle cx="160" cy="160" r="76"  fill="none" stroke="#2D6A4F" stroke-width="1" stroke-dasharray="4 6" opacity="0.25" />

            <!-- Axis lines -->
            <line x1="160" y1="8"   x2="160" y2="312" stroke="#1A3A2A" stroke-width="0.5" opacity="0.12" />
            <line x1="8"   y1="160" x2="312" y2="160" stroke="#1A3A2A" stroke-width="0.5" opacity="0.12" />

            <!-- Spokes from center to grade circles -->
            <line x1="160" y1="122" x2="160" y2="62"  stroke="#C4603A" stroke-width="1.5" opacity="0.6" />
            <line x1="198" y1="160" x2="258" y2="160" stroke="#2D6A4F" stroke-width="1.5" opacity="0.6" />
            <line x1="160" y1="198" x2="160" y2="258" stroke="#2D6A4F" stroke-width="1.5" opacity="0.6" />
            <line x1="122" y1="160" x2="62"  y2="160" stroke="#1A3A2A" stroke-width="1.5" opacity="0.6" />

            <!-- Center: the goal -->
            <circle cx="160" cy="160" r="40" fill="#1A3A2A" />
            <text x="160" y="155" text-anchor="middle" font-family="Georgia, serif" font-size="10" fill="#F5ECD7" letter-spacing="1">COLLEGE</text>
            <text x="160" y="171" text-anchor="middle" font-family="Georgia, serif" font-size="10" fill="#C4603A" letter-spacing="1" font-weight="600">BOUND</text>

            <!-- Grade 9 — top, terracotta -->
            <circle cx="160" cy="40" r="22" fill="#C4603A" />
            <text x="160" y="35" text-anchor="middle" font-family="sans-serif" font-size="7"  fill="rgba(255,255,255,0.75)" letter-spacing="1">GR</text>
            <text x="160" y="49" text-anchor="middle" font-family="Georgia, serif"  font-size="16" fill="white" font-weight="700">9</text>

            <!-- Grade 10 — right, forest -->
            <circle cx="280" cy="160" r="22" fill="#2D6A4F" />
            <text x="280" y="155" text-anchor="middle" font-family="sans-serif" font-size="7"  fill="rgba(255,255,255,0.75)" letter-spacing="1">GR</text>
            <text x="280" y="169" text-anchor="middle" font-family="Georgia, serif"  font-size="16" fill="white" font-weight="700">10</text>

            <!-- Grade 11 — bottom, forest darker -->
            <circle cx="160" cy="280" r="22" fill="#245A42" />
            <text x="160" y="275" text-anchor="middle" font-family="sans-serif" font-size="7"  fill="rgba(255,255,255,0.75)" letter-spacing="1">GR</text>
            <text x="160" y="289" text-anchor="middle" font-family="Georgia, serif"  font-size="16" fill="white" font-weight="700">11</text>

            <!-- Grade 12 — left, darkest forest -->
            <circle cx="40" cy="160" r="22" fill="#1A3A2A" />
            <text x="40"  y="155" text-anchor="middle" font-family="sans-serif" font-size="7"  fill="rgba(245,236,215,0.7)" letter-spacing="1">GR</text>
            <text x="40"  y="169" text-anchor="middle" font-family="Georgia, serif"  font-size="16" fill="#C4603A" font-weight="700">12</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats bar: the broken system -->
  <section class="bg-forest-800 text-white py-8">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div>
          <div class="text-3xl font-serif font-bold text-sand-100">97%</div>
          <div class="text-forest-200 text-xs font-sans mt-1 leading-snug">of families can't afford private counselors</div>
        </div>
        <div class="border-x border-forest-700">
          <div class="text-3xl font-serif font-bold text-terra-400">$15,000</div>
          <div class="text-forest-200 text-xs font-sans mt-1 leading-snug">IvyWise flagship package</div>
        </div>
        <div>
          <div class="text-3xl font-serif font-bold text-sand-100">4 years</div>
          <div class="text-forest-200 text-xs font-sans mt-1 leading-snug">of decisions that shape your child's path</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Journey: visual timeline path -->
  <section class="py-24 bg-white" id="how-it-works">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-lg mb-16">
        <p class="text-terra-500 text-xs font-sans font-bold uppercase tracking-widest mb-3">The 4-year journey</p>
        <h2 class="text-4xl font-serif font-bold text-forest-800 leading-tight">
          One counsellor who grows with your student.
        </h2>
        <p class="text-stone-500 text-base font-sans mt-4 leading-relaxed">
          Every year unlocks new guidance — tuned exactly to where your student is, and what comes next.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Connecting line (desktop only) -->
        <div
          class="hidden md:block absolute top-8 left-[calc(12.5%+0.5rem)] right-[calc(12.5%+0.5rem)] h-px bg-forest-200"
          aria-hidden="true"
        ></div>

        <div class="grid md:grid-cols-4 gap-0 md:gap-8">
          {[
            {
              grade: '9',
              label: 'Foundation',
              bg: 'bg-terra-500',
              desc: 'Course selection, GPA strategy, interest discovery, and extracurricular roadmap.',
            },
            {
              grade: '10',
              label: 'Direction',
              bg: 'bg-forest-600',
              desc: 'PSAT prep, AP planning, summer programs, major exploration, and your first resume.',
            },
            {
              grade: '11',
              label: 'Execution',
              bg: 'bg-forest-700',
              desc: 'SAT/ACT strategy, college list, campus visits, essay brainstorming, rec letter planning.',
            },
            {
              grade: '12',
              label: 'Application',
              bg: 'bg-forest-800',
              desc: 'Common App, supplemental essays, FAFSA, early decision strategy, final college choice.',
            },
          ].map(({ grade, label, bg, desc }) => (
            <div class="relative flex md:flex-col gap-5 md:gap-0 py-6 md:py-0 border-b md:border-b-0 border-sand-200 last:border-0">
              <!-- Grade circle -->
              <div class={`flex-shrink-0 w-16 h-16 md:w-14 md:h-14 rounded-full ${bg} flex flex-col items-center justify-center text-white relative z-10`}>
                <span class="text-[8px] font-sans tracking-widest opacity-75 leading-none uppercase">gr</span>
                <span class="text-xl font-serif font-bold leading-none">{grade}</span>
              </div>
              <div class="pt-1 md:pt-7">
                <div class="font-serif font-bold text-forest-800 text-lg mb-2">{label}</div>
                <p class="text-stone-500 text-sm font-sans leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Differentiator: not ChatGPT -->
  <section class="py-20 bg-sand-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-xl mb-12">
        <h2 class="text-3xl font-serif font-bold text-forest-800 leading-tight">
          Not just another AI chat.
        </h2>
        <p class="text-stone-500 text-base font-sans mt-3 leading-relaxed">
          ChatGPT has no memory of your student, no year-by-year structure, and no deadline accountability.
          ParentCompass does all three — and it never forgets where your student left off.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {[
          {
            num: '01',
            title: 'Persistent student profile',
            desc: "Goals, test scores, activities, and progress live in ParentCompass — not erased after every chat session.",
          },
          {
            num: '02',
            title: 'Year-locked guidance',
            desc: "Grade 9 students aren't overwhelmed with Common App stress. Grade 12 students get laser-focused application support.",
          },
          {
            num: '03',
            title: 'Deadline accountability',
            desc: 'Built-in milestone calendar with alerts for test registration, FAFSA, early decision, and every critical date.',
          },
        ].map(({ num, title, desc }) => (
          <div class="bg-white rounded-xl p-7 border border-sand-200">
            <div class="text-terra-400 font-sans font-bold text-xs tracking-widest mb-4">{num}</div>
            <h3 class="font-serif font-bold text-forest-800 text-xl mb-2">{title}</h3>
            <p class="text-stone-500 text-sm font-sans leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-24 bg-white" id="pricing">
    <div class="max-w-4xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-terra-500 text-xs font-sans font-bold uppercase tracking-widest mb-3">Pricing</p>
        <h2 class="text-4xl font-serif font-bold text-forest-800">Straightforward. Affordable. Family-first.</h2>
        <p class="text-stone-500 text-base font-sans mt-2">One plan covers all four years. Cancel anytime.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Family plan -->
        <div class="border-2 border-forest-800 rounded-2xl p-8 relative">
          <div class="absolute -top-3.5 left-7 bg-terra-500 text-white text-xs font-sans font-bold px-3 py-1 rounded-full tracking-wide">
            Most popular
          </div>
          <p class="text-stone-500 font-sans text-xs font-bold uppercase tracking-widest mb-4">Family</p>
          <div class="flex items-end gap-1 mb-1">
            <span class="text-5xl font-serif font-bold text-forest-800">$199</span>
            <span class="text-stone-400 text-base font-sans mb-2">/year</span>
          </div>
          <p class="text-stone-400 text-sm font-sans mb-7">or $29/month · Up to 2 students</p>
          <ul class="space-y-3 text-sm font-sans text-stone-600 mb-8">
            {[
              'Full 4-year AI counsellor journey',
              'Year-by-year personalised action plans',
              'Unlimited AI chat — student + parent',
              'Parent dashboard: progress & milestones',
              'SAT/ACT planning + college list builder',
              'Common App essay brainstorming',
            ].map(f => (
              <li class="flex items-start gap-2">
                <span class="text-terra-500 font-bold mt-0.5 flex-shrink-0">✓</span> {f}
              </li>
            ))}
          </ul>
          <a
            href="#waitlist"
            class="block bg-forest-800 text-white text-center font-sans font-semibold py-3.5 rounded-lg hover:bg-forest-700 transition-colors"
          >
            Join the Waitlist
          </a>
        </div>

        <!-- Family Plus plan -->
        <div class="border border-sand-200 rounded-2xl p-8 bg-sand-50">
          <p class="text-stone-500 font-sans text-xs font-bold uppercase tracking-widest mb-4">Family Plus</p>
          <div class="flex items-end gap-1 mb-1">
            <span class="text-5xl font-serif font-bold text-forest-800">$49</span>
            <span class="text-stone-400 text-base font-sans mb-2">/month</span>
          </div>
          <p class="text-stone-400 text-sm font-sans mb-7">Everything in Family, plus:</p>
          <ul class="space-y-3 text-sm font-sans text-stone-600 mb-8">
            {[
              'Quarterly 30-min human counsellor call',
              'Essay review with written feedback',
              'Senior year application sprint support',
              'Priority email support',
            ].map(f => (
              <li class="flex items-start gap-2">
                <span class="text-terra-500 font-bold mt-0.5 flex-shrink-0">✓</span> {f}
              </li>
            ))}
          </ul>
          <a
            href="#waitlist"
            class="block border border-forest-300 text-forest-800 text-center font-sans font-semibold py-3.5 rounded-lg hover:bg-forest-50 transition-colors"
          >
            Join the Waitlist
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ: accordion via details/summary -->
  <section class="py-20 bg-sand-50" id="faq">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-serif font-bold text-forest-800 mb-12">Questions parents ask</h2>
      <div class="divide-y divide-sand-200">
        {[
          {
            q: 'Is this only for Indian-American families?',
            a: 'No — ParentCompass works for any family navigating the American high school and college admissions process. We have deep experience with hybrid planning paths (US college + international options), but our core guidance works for all families.',
          },
          {
            q: 'How is this different from ChatGPT?',
            a: "ChatGPT has no memory of your student, no year-by-year structure, and no milestone accountability. ParentCompass builds a persistent profile from Grade 9, unlocks grade-appropriate guidance each year, and keeps both parent and student on track through every deadline.",
          },
          {
            q: 'Can it help with SAT/ACT prep?',
            a: "Yes — ParentCompass generates a personalised SAT/ACT prep plan based on your student's target schools, current score, and timeline. We also connect you with top prep providers when specialised tutoring is needed.",
          },
          {
            q: 'Is the AI advice reliable?',
            a: 'All factual content — Common App rules, AP syllabuses, FAFSA deadlines — is drawn from a curated knowledge base refreshed annually. We do not free-generate facts. For high-stakes decisions, we always recommend consulting your school counsellor alongside our guidance.',
          },
          {
            q: 'When does the product launch?',
            a: 'We are building now and accepting waitlist signups. Waitlist members receive early access and founding-member pricing when we launch.',
          },
        ].map(({ q, a }) => (
          <details class="py-6 cursor-pointer">
            <summary class="flex justify-between items-start gap-4 select-none">
              <h3 class="font-serif font-bold text-forest-800 text-lg leading-snug">{q}</h3>
              <span class="faq-icon text-terra-500 flex-shrink-0 text-2xl leading-none mt-0.5 font-light">+</span>
            </summary>
            <p class="text-stone-500 text-sm font-sans leading-relaxed mt-4 max-w-2xl">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA: terracotta -->
  <section class="bg-terra-500 text-white py-20 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-4xl font-serif font-bold mb-4 leading-tight">
        Start your child's plan today.
      </h2>
      <p class="text-white/80 text-base font-sans mb-8 leading-relaxed">
        Join the waitlist free. Founding-member pricing locked in when we launch.
      </p>
      <a
        href="mailto:hello@parentcompass.ai?subject=Waitlist"
        class="inline-block bg-white text-terra-600 font-sans font-bold px-10 py-4 rounded-lg text-base hover:bg-sand-100 transition-colors"
      >
        Join the Waitlist — Free
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
